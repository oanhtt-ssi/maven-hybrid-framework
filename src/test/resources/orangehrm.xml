<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Orange HRM">
    <listeners>
       <listener class-name="core.MethodListener"></listener>
        <listener class-name="org.uncommons.reportng.HTMLReporter"></listener>
        <listener class-name="org.uncommons.reportng.JUnitXMLReporter"></listener>
    </listeners>

    <parameter name="Url" value="http://localhost:8080/orangehrm"/>
    <test name="Run on CHROME" preserve-order="true">
        <parameter name="Browser" value="Chrome"/>
        <classes>
            <class name="employee.Level_13_Logging"></class>
        </classes>
    </test>

</suite>